# Copy to .env and fill in. NEVER commit .env (it's in .gitignore).

# --- shared ---
OPENAI_API_KEY=           # used by BOTH collection-builder v4 and the assort step

# --- assort step (pipeline/llm.py) ---
LLM_PROVIDER=openai
LLM_MODEL=                # exact API model id for assortment (e.g. gpt-5.5)
# LLM_MAX_TOKENS=4096
# ANTHROPIC_API_KEY=      # only if LLM_PROVIDER=anthropic

# --- collection-builder v4 (categorization) ---
# CB_GATE_MODEL=gpt-4o-mini            # POI/activity gate (override to a current model if you like)
# CB_EMBED_MODEL=text-embedding-3-small
